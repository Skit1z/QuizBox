#!/usr/bin/env bash
# prepare-commit-msg hook：提交前自动递增版本号（+0.01）
# 规则：1.1 → 1.11 → ... → 1.19 → 1.2 → 1.21
# 跳过条件：amend、merge、squash、cherry-pick、或提交信息含 [skip-bump]
# 这些情况下不递增。

COMMIT_MSG_FILE="$1"
COMMIT_SOURCE="$2"

# 跳过非普通提交
case "$COMMIT_SOURCE" in
  merge|squash|commit|template)
    exit 0
    ;;
esac

# 跳过 amend / 含标记
if [ -f "$COMMIT_MSG_FILE" ] && grep -qE '\[skip-bump\]' "$COMMIT_MSG_FILE"; then
  exit 0
fi

# 只在仓库根、且 package.json 存在时执行
ROOT="$(git rev-parse --show-toplevel 2>/dev/null)"
if [ -z "$ROOT" ] || [ ! -f "$ROOT/package.json" ]; then
  exit 0
fi

cd "$ROOT" || exit 0

# 执行递增
node "$ROOT/scripts/bump-version.mjs" >/dev/null 2>&1

# 把变更的版本文件加入本次提交
git add package.json src-tauri/tauri.conf.json src-tauri/Cargo.toml >/dev/null 2>&1

exit 0
