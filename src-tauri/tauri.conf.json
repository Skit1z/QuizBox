{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "题盒",
  "version": "1.35",
  "identifier": "com.quizbox.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build:dev",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "题盒 · QuizBox",
        "width": 1100,
        "height": 760,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
